{
  "name": "sams-still-alive",
  "version": "4.0.0",
  "description": "Play Still Alive and have Speech Synthesis sing it too",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "updateMidi": "tsx ./dev/arrange_lyrics.ts",
    "screenshot": "tsx ./dev/screenshot.ts",
    "smoketest": "tsx ./dev/smoketest.ts",
    "prepare": "svelte-kit sync && husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jan-Ka/sams-still-alive.git"
  },
  "author": "Jan Kaltenecker",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Jan-Ka/sams-still-alive/issues"
  },
  "homepage": "https://github.com/Jan-Ka/sams-still-alive#readme",
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tonejs/midi": "^2.0.28",
    "@types/node": "^25.6.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "playwright": "^1.59.1",
    "postcss": "^8.5.12",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "tone": "^15.1.22"
  }
}
